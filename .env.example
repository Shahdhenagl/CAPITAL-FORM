# ===== Supabase (قاعدة البيانات) =====
# من Supabase: Project Settings > Data API > Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co
# من Supabase: Project Settings > API Keys > service_role (سري جداً — لا تنشره)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== لوحة التحكم (الداش بورد) =====
# كلمة السر اللي هتدخل بيها على /dashboard
DASHBOARD_PASSWORD=ضع-كلمة-سر-قوية
# سر عشوائي لتأمين الجلسة (أي نص طويل عشوائي)
SESSION_SECRET=any-long-random-string-here

# ===== Telegram Bot (إشعارات الطلبات الجديدة) =====
# توكن البوت من @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# معرّف الشات اللي هتوصله الرسايل (من @userinfobot أو getUpdates)
# لإرسال نفس الإشعار لأكتر من شخص: افصلي المعرّفات بفاصلة، مثال: 123456789,987654321
TELEGRAM_CHAT_ID=123456789

# ===== Bevatel (واتساب — إرسال التذكيرات والمواعيد) =====
# رابط منصة بيفاتيل (Chatwoot)
BEVATEL_BASE_URL=https://chat.bevatel.com
# معرف الحساب (Account Id) من رابط اللوحة
BEVATEL_ACCOUNT_ID=40728
# معرّف صندوق الوارد (Inbox Id) المربوط بالواتساب
BEVATEL_INBOX_ID=107608
# رمز المصادقة (Auth Token) — سري، لا تنشره
BEVATEL_API_TOKEN=your-bevatel-auth-token

# ===== Cron (التذكير التلقائي قبل الموعد بيوم) =====
# سر عشوائي لتأمين مسار الـ Cron — ضعيه في إعدادات Vercel بنفس القيمة
CRON_SECRET=any-long-random-string-here
